RewriteEngine On

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^q2m\.io [NC]
RewriteRule ^(.*)$ https://www.q2m.io/$1 [R=301,L]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ── OG Banner — force 200 response for social media crawlers ──
# Prevents Facebook/LinkedIn getting a 206 Partial Content response
<FilesMatch "^og_banner\.jpg$">
  Header always set Accept-Ranges "none"
  Header always set Cache-Control "public, max-age=86400"
</FilesMatch>

# ── Browser Caching ──────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Images — 1 year (they are versioned by filename)
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"

  # CSS & JS — 1 month
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType text/javascript           "access plus 1 month"

  # HTML — 1 hour (so updates propagate quickly)
  ExpiresByType text/html                 "access plus 1 hour"

  # XML (sitemap)
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# ── Cache-Control headers ────────────────────────────────────
<IfModule mod_headers.c>
  # All images — long cache, immutable
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Override for og_banner specifically — shorter cache, no immutable
  <FilesMatch "^og_banner\.jpg$">
    Header set Cache-Control "public, max-age=86400"
    Header always unset Accept-Ranges
    Header always set Accept-Ranges "none"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# ── GZIP Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
</IfModule>
